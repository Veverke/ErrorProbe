{
  "id": null,
  "uid": "errorprobe-namespaces",
  "title": "ErrorProbe — Kubernetes Namespaces",
  "description": "Namespace-level error aggregation for Kubernetes workloads. Only populated when ep is running in K8s mode (runtime=k8s label present). Useful for multi-tenant clusters where errors must be triaged by team.",
  "tags": ["errorprobe"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["15s", "30s", "1m", "5m"],
    "time_options": ["30m", "1h", "3h", "6h", "24h"]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Namespaces with Errors",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(sum by (namespace) (count_over_time({runtime=\"k8s\", level=\"error\"} [$__range]) > 0))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Errors (K8s)",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({runtime=\"k8s\", level=\"error\"} [$__range]))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Warnings (K8s)",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({runtime=\"k8s\", level=\"warn\"} [$__range]))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Errors per Namespace — click to filter",
      "description": "Sorted worst-first. Click a namespace row to set the namespace variable and filter all panels below.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "sortBy": [{ "displayName": "Errors", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Errors" },
              { "id": "custom.width", "value": 100 },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "semi-dark-red", "value": 1 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Warnings" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "namespace" },
            "properties": [{ "id": "displayName", "value": "Namespace" }, { "id": "custom.width", "value": 200 }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (namespace) (count_over_time({runtime=\"k8s\", level=\"error\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{namespace}}",
          "refId": "A"
        },
        {
          "expr": "sum by (namespace) (count_over_time({runtime=\"k8s\", level=\"warn\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{namespace}}",
          "refId": "B"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "renameByName": { "namespace": "Namespace" } } }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Errors per Namespace — bar view",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["sum"], "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (namespace) (count_over_time({runtime=\"k8s\", level=\"error\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error Rate per Namespace",
      "description": "Error rate over time grouped by namespace. Allows comparing blast radius across teams/tenants.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["max", "mean", "sum"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": false,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate({runtime=\"k8s\", level=\"error\"} [2m])",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Errors per Namespace + Container",
      "description": "Drill-down: which containers within each namespace are generating errors. Click container to open the full detail dashboard.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "sortBy": [{ "displayName": "Errors", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "links": [
            {
              "title": "Open Container Detail",
              "url": "/d/errorprobe-detail?var-container=${__data.fields.container}&${__url_time_range}",
              "targetBlank": false
            }
          ]
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Errors" },
              { "id": "custom.width", "value": 100 },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "semi-dark-red", "value": 1 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "namespace" },
            "properties": [{ "id": "displayName", "value": "Namespace" }, { "id": "custom.width", "value": 160 }]
          },
          {
            "matcher": { "id": "byName", "options": "container" },
            "properties": [{ "id": "displayName", "value": "Container" }, { "id": "custom.width", "value": 220 }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (namespace, container) (count_over_time({runtime=\"k8s\", level=\"error\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{namespace}} / {{container}}",
          "refId": "A"
        }
      ],
      "transformations": [{ "id": "merge", "options": {} }]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Recent K8s Error Stream",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{runtime=\"k8s\", level=\"error\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ]
}
