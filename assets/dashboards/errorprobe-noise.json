{
  "id": null,
  "uid": "errorprobe-noise",
  "title": "ErrorProbe — Noise vs Signal",
  "description": "Measures log volume against error ratio per container. High total volume with low error % = noisy but healthy. Low volume with high error % = focused but broken. Use this to tune exclude rules and log levels.",
  "tags": ["errorprobe"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["30s", "1m", "5m"],
    "time_options": ["30m", "1h", "3h", "6h", "24h"]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Log Lines",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".+\"} [$__range]))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Errors",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".+\", level=\"error\"} [$__range]))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Warnings",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".+\", level=\"warn\"} [$__range]))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Log Volume and Error Ratio per Container",
      "description": "Error % = errors ÷ total logs. Red background on Error % = high signal-to-noise (container is in bad shape). High 'Total Logs' with low Error % = noisy but healthy — candidate for ep exclude.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "sortBy": [{ "displayName": "Total Logs", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "container" },
            "properties": [
              { "id": "displayName", "value": "Container" },
              { "id": "custom.width", "value": 250 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Error %" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "semi-dark-yellow", "value": 0.05 },
                    { "color": "semi-dark-red", "value": 0.2 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({container=~\".+\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "A"
        },
        {
          "expr": "sum by (container) (count_over_time({container=~\".+\", level=\"error\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "B"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "calculateField",
          "options": {
            "alias": "Error %",
            "mode": "binary",
            "binary": {
              "left": "Value #B",
              "right": "Value #A",
              "operator": "/"
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "Total Logs",
              "Value #B": "Errors",
              "container": "Container"
            }
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Total Log Volume per Container",
      "description": "Containers emitting the most log lines. High volume can suppress meaningful error signal in log streams and explorers.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["sum"], "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({container=~\".+\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Total Log Rate per Container",
      "description": "Log throughput over time for all levels. Flatlines dropping to zero indicate containers that have stopped logging — cross-reference with the Silent Containers dashboard.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["max", "mean"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": false,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate({container=~\".+\"} [2m])",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    }
  ]
}
