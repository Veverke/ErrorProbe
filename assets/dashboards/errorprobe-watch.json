{
  "id": null,
  "uid": "errorprobe-watch",
  "title": "ErrorProbe — Live Watch",
  "description": "Real-time health view refreshed every 5 s. Mirrors ep watch but in Grafana.",
  "tags": ["errorprobe"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m"],
    "time_options": ["5m", "15m", "30m", "1h", "3h"]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Containers with Errors",
      "description": "Number of distinct containers that logged ≥1 error in the current time window.",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(sum by (container) (count_over_time({container=~\".+\", level=\"error\"} [$__range]) > 0))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Errors",
      "description": "Sum of all error log lines across all containers in the current time window.",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".+\", level=\"error\"} [$__range]))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Warnings",
      "description": "Sum of all warn log lines across all containers in the current time window.",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".+\", level=\"warn\"} [$__range]))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Container Health — sorted worst-first",
      "description": "Errors and warnings per container. Red background = errors present. Click a container name to open the full detail dashboard.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "sortBy": [{ "displayName": "Errors", "desc": true }],
        "footer": { "show": false },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "links": [
            {
              "title": "Open Container Detail",
              "url": "/d/errorprobe-detail?var-container=${__data.fields.container}&${__url_time_range}",
              "targetBlank": false
            }
          ]
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Errors" },
              { "id": "custom.width", "value": 100 },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "semi-dark-red", "value": 1 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Warnings" },
              { "id": "custom.width", "value": 100 },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "semi-dark-yellow", "value": 1 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "container" },
            "properties": [
              { "id": "displayName", "value": "Container" },
              { "id": "custom.width", "value": 250 }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({container=~\".+\", level=\"error\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "A"
        },
        {
          "expr": "sum by (container) (count_over_time({container=~\".+\", level=\"warn\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "B"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": { "container": "Container" }
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Live Error Stream — all containers",
      "description": "Real-time error log lines from every watched container. Auto-scrolls to newest. Expand a line to see full log context.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{container=~\".+\", level=\"error\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "row",
      "title": "All Containers",
      "description": "All containers with any log activity — includes healthy containers that have no errors or warnings.",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Total Active Containers",
      "description": "Distinct containers that have sent any log line in the current time window.",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 25 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(sum by (container) (count_over_time({container=~\".+\"} [$__range]) > 0))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "All Containers — log volume",
      "description": "Every container with any log activity. Containers with zero errors are healthy. Click a name to open the detail dashboard.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "sortBy": [{ "displayName": "Total Lines", "desc": true }],
        "footer": { "show": false },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "links": [
            {
              "title": "Open Container Detail",
              "url": "/d/errorprobe-detail?var-container=${__data.fields.container}&${__url_time_range}",
              "targetBlank": false
            }
          ]
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Total Lines" },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Errors" },
              { "id": "custom.width", "value": 100 },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "color",
                "value": { "mode": "thresholds" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "semi-dark-red", "value": 1 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "container" },
            "properties": [
              { "id": "displayName", "value": "Container" },
              { "id": "custom.width", "value": 250 }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({container=~\".+\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "A"
        },
        {
          "expr": "sum by (container) (count_over_time({container=~\".+\", level=\"error\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "B"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": { "container": "Container" }
          }
        }
      ]
    }
  ]
}
