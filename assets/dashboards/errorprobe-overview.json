{
  "id": null,
  "uid": "errorprobe-overview",
  "title": "ErrorProbe — Overview",
  "tags": ["errorprobe"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Containers with Errors",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(sum by (container) (count_over_time({container=~\".+\", level=\"error\"} [$__range])))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Errors",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".+\", level=\"error\"} [$__range]))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Warnings",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".+\", level=\"warn\"} [$__range]))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Error Count per Container — click to drill down",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "sortBy": [{ "displayName": "Errors", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "links": [
            {
              "title": "Open Container Detail",
              "url": "/d/errorprobe-detail?var-container=${__data.fields.container}&${__url_time_range}",
              "targetBlank": false
            }
          ]
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Errors" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({container=~\".+\", level=\"error\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": { "container": "Container" }
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Recent Errors — All Containers",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{container=~\".+\", level=\"error\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ]
}
