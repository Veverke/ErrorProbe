{
  "id": null,
  "uid": "errorprobe-trends",
  "title": "ErrorProbe — Error Rate Trends",
  "description": "24-hour historical view of error and warning rates per container. Use this to distinguish gradual degradation from acute incidents, and to spot recurring failure windows (e.g. nightly batch jobs).",
  "tags": ["errorprobe"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["1m", "5m", "15m"],
    "time_options": ["6h", "12h", "24h", "48h", "7d"]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Error Rate per Container — 24 h",
      "description": "Errors per second (rate [5m]) per container. A steadily rising baseline means gradual degradation; a sharp cliff means a container went down.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["max", "mean", "sum"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": false,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate({container=~\".+\", level=\"error\"} [5m])",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Warning Rate per Container — 24 h",
      "description": "Warning rate per second. Rising warnings that plateau without becoming errors often indicate resource pressure or retried operations.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["max", "mean", "sum"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": false,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate({container=~\".+\", level=\"warn\"} [5m])",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Total Errors by Container — 24 h",
      "description": "Cumulative error count for the full time window. Sorted by value.",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["sum"], "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({container=~\".+\", level=\"error\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Total Warnings by Container — 24 h",
      "description": "Cumulative warning count for the full time window.",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "loki", "uid": "errorprobe-loki" },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["sum"], "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({container=~\".+\", level=\"warn\"} [$__range]))",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    }
  ]
}
