# Vector configuration for K8s DaemonSet — generated by ErrorProbe
# Runs inside the cluster; reads pod logs directly from node disk.

[sources.k8s_logs]
type = "kubernetes_logs"

[transforms.normalize]
type = "remap"
inputs = ["k8s_logs"]
source = '''
  # Preserve raw message
  raw = to_string(.message) ?? ""
  .raw = raw

  # Normalise timestamp
  if !exists(.timestamp) || !is_timestamp(.timestamp) {
    .timestamp = now()
  }

  # Container / pod metadata
  .container = .kubernetes.container_name
  .runtime = "k8s"
  .pod = .kubernetes.pod_name
  .namespace = .kubernetes.pod_namespace

  # Infer severity level
  msg = raw
  {{- range .ErrorPatterns}}
  if match(msg, r'{{. | escapeVRLPattern}}') {
    .level = "error"
  } else
  {{- end}}
  {{- range .WarnPatterns}}
  if match(msg, r'{{. | escapeVRLPattern}}') {
    .level = "warn"
  } else
  {{- end}}
  {
    .level = "info"
  }
'''

[sinks.loki]
type = "loki"
inputs = ["normalize"]
endpoint = "http://${HOST_IP}:{{.LokiPort}}"

[sinks.loki.labels]
container = "{{ "{{" }} .container {{ "}}" }}"
level = "{{ "{{" }} .level {{ "}}" }}"
runtime = "{{ "{{" }} .runtime {{ "}}" }}"
pod = "{{ "{{" }} .pod {{ "}}" }}"
namespace = "{{ "{{" }} .namespace {{ "}}" }}"

[sinks.loki.encoding]
codec = "json"

[sinks.errorprobe_ingest]
type = "http"
inputs = ["normalize"]
uri = "http://host.docker.internal:{{.IngestPort}}/ingest"
method = "post"

[sinks.errorprobe_ingest.encoding]
codec = "json"

[sinks.errorprobe_ingest.batch]
max_events = 100
timeout_secs = 1
