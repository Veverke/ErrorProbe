# Vector configuration — generated by ErrorProbe (v2)

[sources.docker_logs]
type = "docker_logs"
include_containers = [{{range $i, $c := .Containers}}{{if $i}}, {{end}}"{{$c}}"{{end}}]

[transforms.normalize]
type = "remap"
inputs = ["docker_logs"]
source = '''
  # Preserve raw message
  raw = to_string(.message) ?? ""
  .raw = raw

  # Normalise timestamp
  if !exists(.timestamp) || !is_timestamp(.timestamp) {
    .timestamp = now()
  }

  # Container name from Vector metadata
  .container = .container_name

  # Infer severity level
  msg = raw
  {{- range .ErrorPatterns}}
  if match(msg, r'{{. | escapeVRLPattern}}') {
    .level = "error"
  } else
  {{- end}}
  {{- range .WarnPatterns}}
  if match(msg, r'{{. | escapeVRLPattern}}') {
    .level = "warn"
  } else
  {{- end}}
  {
    .level = "info"
  }
'''

[sinks.loki]
type = "loki"
inputs = ["normalize"]
endpoint = "http://{{.LokiHost}}:{{.LokiPort}}"

[sinks.loki.labels]
container = "{{ "{{" }} .container {{ "}}" }}"
level = "{{ "{{" }} .level {{ "}}" }}"

[sinks.loki.encoding]
codec = "json"

# NOTE: The errorprobe_ingest sink requires the ingest endpoint to be reachable
# from within the Vector container. If IngestBind is 127.0.0.1, Vector will not
# be able to reach the host process. Use a host alias, a containerized ingest
# service, or replace IngestBind with the appropriate host address (e.g.,
# host.docker.internal) before enabling this sink.
{{- if .IngestEnabled}}
[sinks.errorprobe_ingest]
type = "http"
inputs = ["normalize"]
uri = "http://{{.IngestHost}}:{{.IngestPort}}/ingest"
method = "post"

[sinks.errorprobe_ingest.encoding]
codec = "json"

[sinks.errorprobe_ingest.batch]
max_events = 100
timeout_secs = 1
{{- end}}