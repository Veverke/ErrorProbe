# Vector configuration — generated by ErrorProbe (v2)

{{- if .DockerContainers}}
[sources.docker_logs]
type = "docker_logs"
include_containers = [{{range $i, $c := .DockerContainers}}{{if $i}}, {{end}}"{{$c}}"{{end}}]
{{- end}}

{{- if .K8sContainers}}
[sources.k8s_logs]
type = "kubernetes_logs"
{{- end}}

[transforms.normalize]
type = "remap"
inputs = [{{if and .DockerContainers .K8sContainers}}"docker_logs", "k8s_logs"{{else if .DockerContainers}}"docker_logs"{{else}}"k8s_logs"{{end}}]
source = '''
  # Preserve raw message
  raw = to_string(.message) ?? ""
  .raw = raw

  # Normalise timestamp
  if !exists(.timestamp) || !is_timestamp(.timestamp) {
    .timestamp = now()
  }

  # Container name from Vector metadata
  if exists(.container_name) {
    .container = .container_name
    .runtime = "docker"
  } else if exists(.kubernetes.pod_name) {
    .container = .kubernetes.pod_name + "/" + .kubernetes.container_name
    .runtime = "k8s"
    .pod = .kubernetes.pod_name
    .namespace = .kubernetes.pod_namespace
  } else {
    .container = "unknown"
    .runtime = "unknown"
  }

  # Infer severity level
  msg = raw
  {{- range .ErrorPatterns}}
  if match(msg, r'{{. | escapeVRLPattern}}') {
    .level = "error"
  } else
  {{- end}}
  {{- range .WarnPatterns}}
  if match(msg, r'{{. | escapeVRLPattern}}') {
    .level = "warn"
  } else
  {{- end}}
  {
    .level = "info"
  }
'''

[sinks.loki]
type = "loki"
inputs = ["normalize"]
endpoint = "http://{{.LokiHost}}:{{.LokiPort}}"

[sinks.loki.labels]
container = "{{ "{{" }} .container {{ "}}" }}"
level = "{{ "{{" }} .level {{ "}}" }}"
runtime = "{{ "{{" }} .runtime {{ "}}" }}"
pod = "{{ "{{" }} .pod {{ "}}" }}"
namespace = "{{ "{{" }} .namespace {{ "}}" }}"

[sinks.loki.encoding]
codec = "json"

# NOTE: The errorprobe_ingest sink requires the ingest endpoint to be reachable
# from within the Vector container. If IngestBind is 127.0.0.1, Vector will not
# be able to reach the host process. Use a host alias, a containerized ingest
# service, or replace IngestBind with the appropriate host address (e.g.,
# host.docker.internal) before enabling this sink.
{{- if .IngestEnabled}}
[sinks.errorprobe_ingest]
type = "http"
inputs = ["normalize"]
uri = "http://{{.IngestHost}}:{{.IngestPort}}/ingest"
method = "post"

[sinks.errorprobe_ingest.encoding]
codec = "json"

[sinks.errorprobe_ingest.batch]
max_events = 100
timeout_secs = 1
{{- end}}