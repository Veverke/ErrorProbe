# Vector configuration — generated by ErrorProbe

[sources.docker_logs]
type = "docker_logs"
include_containers = [{{range $i, $c := .Containers}}{{if $i}}, {{end}}"{{$c}}"{{end}}]

[transforms.normalize]
type = "remap"
inputs = ["docker_logs"]
source = '''
  raw = string!(.message)

  # Attempt JSON parse; fall back to raw string
  parsed, err = parse_json(raw)
  if err == null {
    ., err = merge(., object!(parsed))
    if err != null { .message = raw }
  } else {
    .message = raw
  }

  # Normalise timestamp
  if exists(.timestamp) {
    ts, err = to_timestamp(.timestamp)
    if err == null { .timestamp = ts } else { .timestamp = now() }
  } else {
    .timestamp = now()
  }

  # Container name from Vector metadata
  .container = .container_name

  # Infer severity level
  msg = string!(.message)
  {{- range .ErrorPatterns}}
  if match(msg, r'{{.}}') {
    .level = "error"
  } else
  {{- end}}
  {{- range .WarnPatterns}}
  if match(msg, r'{{.}}') {
    .level = "warn"
  } else
  {{- end}}
  {
    .level = "info"
  }

  # Preserve raw unparsed line
  .raw = raw
'''

[sinks.loki]
type = "loki"
inputs = ["normalize"]
endpoint = "http://loki:{{.LokiPort}}"

[sinks.loki.labels]
container = "{{ "{{" }} .container {{ "}}" }}"
level = "{{ "{{" }} .level {{ "}}" }}"

[sinks.loki.encoding]
codec = "json"

[sinks.errorprobe_ingest]
type = "http"
inputs = ["normalize"]
uri = "http://{{.IngestBind}}:{{.IngestPort}}/ingest"
method = "post"

[sinks.errorprobe_ingest.encoding]
codec = "json"

[sinks.errorprobe_ingest.batch]
max_events = 100
timeout_secs = 1
